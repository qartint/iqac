# Unified Backend — Environment Variables
# Copy this file to .env and fill in your values.
# This .env is used by the ROOT server.js (unified backend).
#
# The individual naac-backend-main and ProfCV-main/server sub-directories
# also have their own .env files for when running independently during migration.

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
# Single shared MongoDB URI — all modules connect to the same database.
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.example.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── JWT ───────────────────────────────────────────────────────────────────────
# MUST be the same secret used across all modules so tokens are interoperable.
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=1d

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,https://profcv-kuc.netlify.app

# ── Email (naac OTP flow) ─────────────────────────────────────────────────────
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# ── Cloudinary (naac file uploads) ───────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
